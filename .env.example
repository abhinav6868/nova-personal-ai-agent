# Get this free at https://aistudio.google.com -> Get API Key
GOOGLE_API_KEY=your_gemini_api_key_here

# Get this free from @BotFather on Telegram (message /newbot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram numeric user id (message @userinfobot to get it)
# Used so the agent only responds to you, and knows who to message
# during scheduled/proactive jobs.
TELEGRAM_USER_ID=your_telegram_user_id_here
